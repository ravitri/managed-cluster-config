{
  "Version": "2012-10-17",
  "Statement": [
    {
      "action": [
        "ec2:AttachVolume",
        "ec2:CreateSnapshot",
        "ec2:CreateTags",
        "ec2:CreateVolume",
        "ec2:DeleteSnapshot",
        "ec2:DeleteTags",
        "ec2:DeleteVolume",
        "ec2:DescribeInstances",
        "ec2:DescribeSnapshots",
        "ec2:DescribeTags",
        "ec2:DescribeVolumes",
        "ec2:DescribeVolumesModifications",
        "ec2:DetachVolume",
        "ec2:ModifyVolume",
        "ec2:DescribeAvailabilityZones",
        "ec2:EnableFastSnapshotRestores"
      ],
      "effect": "Allow",
      "resource": "*"
    },
    {
      "action": [
        "kms:ReEncrypt*",
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:GenerateDataKeyWithoutPlainText",
        "kms:DescribeKey"
      ],
      "effect": "Allow",
      "resource": "*"
    },
    {
      "action": [
        "kms:RevokeGrant",
        "kms:CreateGrant",
        "kms:ListGrants"
      ],
      "effect": "Allow",
      "policyCondition": {
        "Bool": {
          "kms:GrantIsForAWSResource": true
        }
      },
      "resource": "*"
    }
  ]
}